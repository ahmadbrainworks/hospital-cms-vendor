# ============================================================
# CONTROL PANEL — Environment Variables
# Copy to .env and fill in real values.
# Used by `docker compose --env-file .env up -d --build`
# for the vendor control-panel stack.
# ============================================================

# --- Public URL exposed to staff users and hospital agents ---
# Example local test URL: http://localhost:8080
VENDOR_PUBLIC_ORIGIN=http://localhost:8080
VENDOR_DASHBOARD_ORIGIN=http://localhost:3003

# --- Local Control Panel Runtime ---
CONTROL_PANEL_PORT=4001
CONTROL_PANEL_MONGODB_URI=mongodb://localhost:27017/hospital_cp

# --- Vendor API Key (HMAC auth for CLI/automation tools) ---
VENDOR_API_KEY=REPLACE_WITH_STRONG_RANDOM_STRING

# --- RSA-4096 Key Pair (signs licenses, commands, packages) ---
# Keys are in .data/vendor.key (private) and .data/vendor.pub (public).
# The public key is also embedded in hospital-cms-hospital/packages/config/src/paths.ts.
# Load from file:  VENDOR_PRIVATE_KEY=$(cat .data/vendor.key)
#                  VENDOR_PUBLIC_KEY=$(cat .data/vendor.pub)
VENDOR_PRIVATE_KEY=
VENDOR_PUBLIC_KEY=

# --- Staff Authentication (JWT — separate from client CMS) ---
# Generate secrets with: openssl rand -hex 32
CP_JWT_SECRET=REPLACE_WITH_64_CHAR_HEX
CP_JWT_EXPIRY=15m
CP_REFRESH_TOKEN_SECRET=REPLACE_WITH_64_CHAR_HEX
CP_REFRESH_TOKEN_EXPIRY=7d

# --- Initial Admin Account (used on first startup only) ---
CP_INITIAL_ADMIN_EMAIL=admin@yourvendor.com
CP_INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Logging ---
LOG_LEVEL=info
